# Canonical site URL for SEO (no trailing slash). Used at build time for
# og:image, canonical, robots.txt, and sitemap.xml.
# GitHub Pages (project site):
# VITE_SITE_URL=https://fateavalon.github.io/bibliocommons-search-in-douban
# Cloudflare Pages (root deploy):
# VITE_SITE_URL=https://your-project.pages.dev

# Optional: Douban image proxy (see existing deploy workflow)
# VITE_IMG_PROXY_BASE=https://douban-img.fateacher.com/
